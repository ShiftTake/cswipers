rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'nathanjohns309@gmail.com';
    }

    match /cards/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isAdmin() || (signedIn() && request.auth.uid == userId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
